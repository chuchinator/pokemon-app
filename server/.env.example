# Copy to server/.env — run: npm run sync:server

# Signs login sessions (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Optional legacy single-user token (not used by the app anymore)
# POKEFOLIO_TOKEN=

PORT=3456
CORS_ORIGIN=https://chuchinator.github.io

# Set once by npm run tunnel:setup (stable public URL)
# TUNNEL_PUBLIC_URL=https://pokefolio.yourdomain.com
