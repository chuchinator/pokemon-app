# Copy to server/.env and run: npm run sync:server
# (Keep server/.env private — never commit it.)

# Same long random string as GitHub secret VITE_SYNC_TOKEN
POKEFOLIO_TOKEN=change-me-to-a-long-random-string

PORT=3456

# Must match the browser Origin (not the /pokemon-app/ path)
CORS_ORIGIN=https://chuchinator.github.io

# Public HTTPS URL that reaches this PC (Cloudflare Tunnel, ngrok, etc.)
# Use the same value for GitHub secret VITE_SYNC_URL — no trailing slash.
# SYNC_PUBLIC_URL=https://pokefolio.yourdomain.com
